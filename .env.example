# Copy to .env and adjust.
#
# Defaults below assume the local-first path: Ollama running on the host
# (LLM + embeddings) and the docker-compose stack for Milvus, Neo4j, SearXNG.
# To switch to the CI-tier setup (Ollama Cloud LLM + OpenAI embeddings),
# uncomment the lines marked "CI-tier" and comment out the local ones.

# ---- LLM via Ollama ----
# Local (default): run on host with `ollama serve`,
#   then: `ollama pull qwen2.5:7b`
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b
# CI-tier (Ollama Cloud — set OLLAMA_API_KEY, switch the two lines above):
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_API_KEY=
# LLM_MODEL=kimi-k2.6

# ---- Embeddings ----
# "ollama" (local bge-m3, 1024-dim) or "openai" (text-embedding-3-large, 3072-dim).
# Ollama Cloud has no embeddings endpoint, so cloud-LLM setups use OpenAI here.
EMBED_PROVIDER=ollama
EMBED_MODEL=bge-m3
EMBED_DIM=1024
# CI-tier (OpenAI; flip provider and bump dim — must match the Milvus collection):
# EMBED_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_EMBED_MODEL=text-embedding-3-large
# EMBED_DIM=3072

# ---- Milvus ----
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=sovereign_chunks

# ---- Neo4j ----
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sovereign-dev-pw
NEO4J_DATABASE=neo4j

# ---- Web ingestion ----
# docker-compose publishes SearXNG on host port 8082 (not 8080) to avoid
# colliding with any SearXNG you may already run.
SEARXNG_URL=http://localhost:8082

# ---- LangGraph orchestration ----
# Postgres URI for the AsyncPostgresSaver. docker-compose publishes Postgres
# on host port 5433 (5432 is often already in use).
POSTGRES_PASSWORD=sovereign-dev-pw
LANGGRAPH_PG_URI=postgresql://sovereign:sovereign-dev-pw@localhost:5433/sovereign_lg
# Web fallback fires when local retrieval returns fewer than N candidates.
# Set to 0 to disable.
WEB_FALLBACK_MIN_CHUNKS=3
WEB_FALLBACK_MAX_URLS=3

# ---- Retrieval knobs ----
RETRIEVE_TOP_K=50
RERANK_TOP_K=5
ENABLE_CONTEXTUAL_RETRIEVAL=true
ENABLE_GRAPH_RETRIEVAL=true

# ---- Reranker (cross-encoder via sentence-transformers) ----
# Default is the SOTA multilingual model; weights downloaded once from HF (~1 GB)
# and cached locally. Inference is on-prem (MPS / CUDA / CPU).
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=auto   # auto | mps | cuda | cpu

# ---- Observability — LangSmith (optional, default off) ----
# When LANGSMITH_TRACING=true every LangGraph node + LangChain call
# lights up in https://smith.langchain.com/o/<org>/projects/p/<project>.
# Picked up automatically by langchain-core; no app code change needed.
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=sovereign-rag

# ---- Observability — Langfuse (optional, default off) ----
# Self-hosted or cloud. The python wrapper attaches a Langchain
# CallbackHandler to every LLM/chain call when ENABLE_LANGFUSE=true and
# the three credentials below are present. Defaults match the Mac Mini
# compose stack from the langfuse-* containers.
ENABLE_LANGFUSE=false
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=http://localhost:3100
# LANGFUSE_HOST=http://localhost:3100   # legacy alias
