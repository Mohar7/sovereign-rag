# Front-end env. Copy to .env (Vite loads .env automatically).

# Where LangGraph is reachable. Leave blank to use the Vite proxy
# (which forwards to localhost:2024 — the local `langgraph dev` server).
# In production, point this at your deployed LangGraph URL.
VITE_LANGGRAPH_URL=

# The assistant / graph id from `langgraph.json`. Defaults to sovereign_qa.
VITE_LANGGRAPH_ASSISTANT=sovereign_qa

# API key for LangGraph Platform deployments. Empty for local `langgraph dev`.
VITE_LANGGRAPH_API_KEY=
