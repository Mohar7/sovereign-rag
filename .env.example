# Copy to .env and adjust. Everything is local — no paid API keys.

# ---- Ollama (run on host: `ollama serve`) ----
# Pull models first:  ollama pull qwen2.5:7b && ollama pull bge-m3
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# ---- Milvus ----
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=sovereign_chunks

# ---- Neo4j ----
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sovereign-dev-pw
NEO4J_DATABASE=neo4j

# ---- Web ingestion ----
SEARXNG_URL=http://localhost:8080

# ---- Retrieval knobs ----
RETRIEVE_TOP_K=50
RERANK_TOP_K=5
ENABLE_CONTEXTUAL_RETRIEVAL=true
ENABLE_GRAPH_RETRIEVAL=true

# ---- Observability (optional) ----
ENABLE_LANGFUSE=false
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=
